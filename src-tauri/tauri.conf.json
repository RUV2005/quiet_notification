{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick_notification",
  "version": "0.1.0",
  "identifier": "com.quick_notification.app",
  "build": { "frontendDist": "../src" },
  "app": {
    "windows": [{
      "title": "通知助手",
      "width": 660,
      "height": 580,
      "resizable": false,
      "decorations": false,
      "transparent": true,
      "alwaysOnTop": false,
      "shadow": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"]
  }
}